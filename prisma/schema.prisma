generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model TradeRecord {
  id            String      @id @default(uuid())
  market        Market
  exchangeCode  String?     @map("exchange_code")
  stockCode     String      @map("stock_code")
  stockName     String      @map("stock_name")
  side          Side
  orderType     OrderType   @map("order_type")
  quantity      Int
  price         Decimal
  executedPrice Decimal?    @map("executed_price")
  executedQty   Int?        @map("executed_qty")
  orderNo       String?     @map("order_no")
  status        OrderStatus
  strategyName  String?     @map("strategy_name")
  reason        String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  stopLossApprovals StopLossApproval[]

  @@map("trade_records")
}

model Position {
  id            String   @id @default(uuid())
  market        Market
  exchangeCode  String?  @map("exchange_code")
  stockCode     String   @map("stock_code")
  stockName     String   @map("stock_name")
  quantity      Int
  avgPrice      Decimal  @map("avg_price")
  currentPrice  Decimal  @map("current_price")
  profitLoss    Decimal  @map("profit_loss")
  profitRate    Decimal  @map("profit_rate")
  totalInvested Decimal  @default(0) @map("total_invested") @db.Decimal(16, 4)
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([market, stockCode])
  @@map("positions")
}

model WatchStock {
  id               String   @id @default(uuid())
  market           Market
  exchangeCode     String?  @map("exchange_code")
  stockCode        String   @map("stock_code")
  stockName        String   @map("stock_name")
  isActive         Boolean  @default(true) @map("is_active")
  strategyName     String?  @map("strategy_name")
  quota            Decimal? @db.Decimal(12, 2)
  cycle            Int      @default(0)
  maxCycles        Int      @default(40) @map("max_cycles")
  stopLossRate     Decimal  @default(0.3) @map("stop_loss_rate") @db.Decimal(4, 3)
  maxPortfolioRate Decimal  @default(0.2) @map("max_portfolio_rate") @db.Decimal(4, 3)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  strategyParams   Json?    @map("strategy_params")

  @@unique([market, stockCode])
  @@map("watch_stocks")
}



model RiskSnapshot {
  id             String   @id @default(uuid())
  market         Market
  snapshotDate   String   @map("snapshot_date")
  portfolioValue Decimal  @map("portfolio_value") @db.Decimal(16, 4)
  cashBalance    Decimal  @map("cash_balance") @db.Decimal(16, 4)
  dailyPnl       Decimal  @map("daily_pnl") @db.Decimal(16, 4)
  dailyPnlRate   Decimal  @map("daily_pnl_rate") @db.Decimal(8, 6)
  drawdown       Decimal  @db.Decimal(8, 6)
  peakValue      Decimal  @map("peak_value") @db.Decimal(16, 4)
  positionCount  Int      @map("position_count")
  investedRate   Decimal  @map("invested_rate") @db.Decimal(8, 6)
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([market, snapshotDate])
  @@map("risk_snapshots")
}

model StrategyAllocation {
  id             String   @id @default(uuid())
  market         Market
  strategyName   String   @map("strategy_name")
  allocationRate Decimal  @map("allocation_rate") @db.Decimal(4, 3)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([market, strategyName])
  @@map("strategy_allocations")
}

model KisToken {
  id          String   @id @default("kis_access_token")
  accessToken String   @map("access_token")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("kis_tokens")
}

model StockRecommendation {
  id                  String   @id @default(uuid())
  screeningDate       String   @map("screening_date")
  market              Market
  exchangeCode        String   @map("exchange_code")
  stockCode           String   @map("stock_code")
  stockName           String   @map("stock_name")
  totalScore          Decimal  @map("total_score") @db.Decimal(6, 2)
  technicalScore      Decimal  @map("technical_score") @db.Decimal(6, 2)
  fundamentalScore    Decimal  @map("fundamental_score") @db.Decimal(6, 2)
  momentumScore       Decimal  @map("momentum_score") @db.Decimal(6, 2)
  rank                Int
  reasons             Json
  indicators          Json
  currentPrice        Decimal  @map("current_price") @db.Decimal(16, 4)
  changeRate          Decimal  @map("change_rate") @db.Decimal(8, 4)
  volume              BigInt   @default(0)
  marketCap           BigInt   @default(0) @map("market_cap")
  isEtf               Boolean  @default(false) @map("is_etf")
  createdAt           DateTime @default(now()) @map("created_at")
  suggestedStrategies Json?    @map("suggested_strategies")

  @@unique([screeningDate, market, stockCode])
  @@index([screeningDate, market])
  @@index([screeningDate, market, isEtf])
  @@map("stock_recommendations")
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model SimulationSession {
  id             String                 @id @default(uuid())
  name           String
  description    String?
  market         Market
  strategyName   String                 @map("strategy_name")
  status         SimulationStatus       @default(RUNNING)
  initialCapital Decimal                @map("initial_capital") @db.Decimal(16, 4)
  currentCash    Decimal                @map("current_cash") @db.Decimal(16, 4)
  startedAt      DateTime               @default(now()) @map("started_at")
  stoppedAt      DateTime?              @map("stopped_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  countryCode    String?                @map("country_code")
  positions      SimulationPosition[]
  snapshots      SimulationSnapshot[]
  trades         SimulationTrade[]
  watchStocks    SimulationWatchStock[]

  @@map("simulation_sessions")
}

model SimulationWatchStock {
  id               String            @id @default(uuid())
  sessionId        String            @map("session_id")
  market           Market
  exchangeCode     String?           @map("exchange_code")
  stockCode        String            @map("stock_code")
  stockName        String            @map("stock_name")
  quota            Decimal?          @db.Decimal(12, 2)
  cycle            Int               @default(0)
  maxCycles        Int               @default(40) @map("max_cycles")
  stopLossRate     Decimal           @default(0.3) @map("stop_loss_rate") @db.Decimal(4, 3)
  maxPortfolioRate Decimal           @default(0.2) @map("max_portfolio_rate") @db.Decimal(4, 3)
  strategyParams   Json?             @map("strategy_params")
  isActive         Boolean           @default(true) @map("is_active")
  session          SimulationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, stockCode])
  @@map("simulation_watch_stocks")
}

model SimulationTrade {
  id           String            @id @default(uuid())
  sessionId    String            @map("session_id")
  market       Market
  exchangeCode String?           @map("exchange_code")
  stockCode    String            @map("stock_code")
  stockName    String            @map("stock_name")
  side         Side
  quantity     Int
  price        Decimal           @db.Decimal(16, 4)
  totalAmount  Decimal           @map("total_amount") @db.Decimal(16, 4)
  strategyName String?           @map("strategy_name")
  reason       String?
  createdAt    DateTime          @default(now()) @map("created_at")
  session      SimulationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("simulation_trades")
}

model SimulationPosition {
  id            String            @id @default(uuid())
  sessionId     String            @map("session_id")
  market        Market
  exchangeCode  String?           @map("exchange_code")
  stockCode     String            @map("stock_code")
  stockName     String            @map("stock_name")
  quantity      Int
  avgPrice      Decimal           @map("avg_price") @db.Decimal(16, 4)
  currentPrice  Decimal           @map("current_price") @db.Decimal(16, 4)
  totalInvested Decimal           @map("total_invested") @db.Decimal(16, 4)
  profitLoss    Decimal           @map("profit_loss") @db.Decimal(16, 4)
  profitRate    Decimal           @map("profit_rate") @db.Decimal(8, 6)
  updatedAt     DateTime          @updatedAt @map("updated_at")
  session       SimulationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, stockCode])
  @@map("simulation_positions")
}

model SimulationSnapshot {
  id             String            @id @default(uuid())
  sessionId      String            @map("session_id")
  snapshotDate   String            @map("snapshot_date")
  portfolioValue Decimal           @map("portfolio_value") @db.Decimal(16, 4)
  cashBalance    Decimal           @map("cash_balance") @db.Decimal(16, 4)
  totalValue     Decimal           @map("total_value") @db.Decimal(16, 4)
  dailyPnl       Decimal           @map("daily_pnl") @db.Decimal(16, 4)
  dailyPnlRate   Decimal           @map("daily_pnl_rate") @db.Decimal(8, 6)
  drawdown       Decimal           @db.Decimal(8, 6)
  peakValue      Decimal           @map("peak_value") @db.Decimal(16, 4)
  positionCount  Int               @map("position_count")
  tradeCount     Int               @map("trade_count")
  createdAt      DateTime          @default(now()) @map("created_at")
  session        SimulationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, snapshotDate])
  @@map("simulation_snapshots")
}

enum Market {
  DOMESTIC
  OVERSEAS
}

enum Side {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  LOC
}

enum OrderStatus {
  PENDING
  FILLED
  PARTIAL
  CANCELLED
  FAILED
  AWAITING_APPROVAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model StopLossApproval {
  id             String         @id @default(uuid())
  tradeRecordId  String         @map("trade_record_id")
  market         Market
  exchangeCode   String?        @map("exchange_code")
  stockCode      String         @map("stock_code")
  stockName      String         @map("stock_name")
  strategyName   String?        @map("strategy_name")
  signal         Json
  currentPrice   Decimal        @map("current_price") @db.Decimal(16, 4)
  avgPrice       Decimal        @map("avg_price") @db.Decimal(16, 4)
  quantity       Int
  lossRate       Decimal        @map("loss_rate") @db.Decimal(8, 6)
  status         ApprovalStatus @default(PENDING)
  slackMessageTs String?        @map("slack_message_ts")
  slackChannel   String?        @map("slack_channel")
  requestedAt    DateTime       @default(now()) @map("requested_at")
  respondedAt    DateTime?      @map("responded_at")
  timeoutMinutes Int            @default(5) @map("timeout_minutes")
  tradeRecord    TradeRecord    @relation(fields: [tradeRecordId], references: [id])

  @@map("stop_loss_approvals")
}


enum SimulationStatus {
  RUNNING
  PAUSED
  COMPLETED
}
